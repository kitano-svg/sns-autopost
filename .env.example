# ローカルでテストする時だけ使う。このファイルを .env という名前でコピーして値を入れる。
# .env は .gitignore 済みなのでGitHubには上がりません（＝安全）。
# 本番(GitHub Actions)ではこのファイルは使わず、GitHub Secretsの値が使われます。

# --- リサーチ用 ---
ANTHROPIC_API_KEY=

# --- AI背景画像用 ---
GEMINI_API_KEY=

# --- X (Twitter) ---
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# --- Instagram ---
IG_USER_ID=
IG_ACCESS_TOKEN=

# Instagramをローカルからテスト投稿する時だけ必要（画像の公開URL）。
# 本番ではActionsが自動でraw.githubusercontent.comのURLを入れるので不要。
IMAGE_URL=
