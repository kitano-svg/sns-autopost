# ローカルでテストする時だけ使う。このファイルを .env という名前でコピーして値を入れる。
# .env は .gitignore 済みなのでGitHubには上がりません（＝安全）。
# 本番(GitHub Actions)ではこのファイルは使わず、GitHub Secretsの値が使われます。

# --- リサーチ用 ---
ANTHROPIC_API_KEY=

# --- AI背景画像用 ---
GEMINI_API_KEY=

# --- X (Twitter) ---
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# --- 候補メール送信 (Resend) ---
# resend.com で発行するAPIキー。GitHub Secrets の RESEND_API_KEY にも登録する。
RESEND_API_KEY=
# 送信元。独自ドメイン検証前は onboarding@resend.dev（自分宛のみ送れる）でOK
RESEND_FROM=onboarding@resend.dev
# 候補メールの宛先（未設定なら config.json の reviewerEmail）
REVIEWER_EMAIL=kitano@createrium.co.jp
# 承認ページのURL（メール内リンク用。未設定なら config.json の dashboardUrl）
DASHBOARD_URL=https://sns-dashboard-xi.vercel.app

# --- 予約キューをローカルから処理する時だけ（本番はActions組み込みのGITHUB_TOKEN）---
GITHUB_TOKEN=

# --- Instagram（現在ステップはスキップ中）---
IG_USER_ID=
IG_ACCESS_TOKEN=

# Instagramをローカルからテスト投稿する時だけ必要（画像の公開URL）。
# 本番ではActionsが自動でraw.githubusercontent.comのURLを入れるので不要。
IMAGE_URL=
